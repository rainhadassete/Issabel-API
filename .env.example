# Database
DB_HOST=192.168.70.3
DB_PORT=3306
DB_USER=api
DB_PASSWORD=your_password_here
DB_NAME=asteriskcdrdb
DB_CONNECTION_LIMIT=10

# JWT
JWT_SECRET=change-this-to-a-strong-random-secret
JWT_EXPIRES_IN=24h

# Admin seed
ADMIN_USERNAME=admin
ADMIN_PASSWORD=admin

# SSH (para download de gravações via SFTP)
SSH_HOST=192.168.70.3
SSH_PORT=22
SSH_USER=root
SSH_PASSWORD=
RECORDINGS_PATH=/var/spool/asterisk/monitor

# Whisper (transcrição offline)
WHISPER_BIN=./whisper/whisper-cli
WHISPER_MODELS_DIR=./whisper/models
WHISPER_MODEL=ggml-small.bin

# Background transcription worker (auto-transcribes new recordings)
TRANSCRIPTION_WORKER_ENABLED=true
TRANSCRIPTION_WORKER_INTERVAL_MS=60000
TRANSCRIPTION_WORKER_BATCH_SIZE=5
TRANSCRIPTION_WORKER_MIN_AGE_SECONDS=30
TRANSCRIPTION_WORKER_MAX_CONSECUTIVE_ERRORS=10

# Server
PORT=3000
NODE_ENV=development
